# Conversation intelligence (required for the natural Fatima agent)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

# Speech-to-text
DEEPGRAM_API_KEY=your_deepgram_api_key

# Text-to-speech
# auto selects ElevenLabs when both values below are configured, otherwise Azure.
TTS_PROVIDER=auto
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_fatima_voice_id
ELEVENLABS_FATIMA_AGENT_ID=your_elevenlabs_realtime_agent_id
# Urdu is supported by Eleven v3; Flash v2.5 does not currently list Urdu.
ELEVENLABS_MODEL=eleven_v3
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_VOICE=ur-PK-UzmaNeural
